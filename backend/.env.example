APP_NAME="Euro Park API"
DEBUG=true
DATABASE_URL="sqlite+aiosqlite:///./euro_park.db"
JWT_SECRET="PLACEHOLDER"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# JSON array of allowed frontend origins. Defaults to ["http://localhost:3000"]
# if unset — override this if the frontend is served from elsewhere.
CORS_ORIGINS=["http://localhost:3000"]
