# Server-side (SSR) base URL. Defaults to http://backend:8000, which only
# resolves inside the docker-compose network. Running `npm run dev` outside
# Docker? Override this to http://localhost:8000 (or wherever the backend runs).
NUXT_API_BASE=http://localhost:8000

# Client-side (browser) base URL.
NUXT_PUBLIC_API_BASE=http://localhost:8000
